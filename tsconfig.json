{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "strict": true,
    "noImplicitReturns": true,     // Щоб не забути return (як у Java)
    "noUnusedLocals": true,        // Чистота коду
    "esModuleInterop": true,
    "sourceMap": true,
    "skipLibCheck": true,
  },
  "include": [
    "src/**/*",
    "prisma/generated/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}