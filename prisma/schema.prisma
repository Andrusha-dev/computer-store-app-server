// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator zod {
  provider                  = "zod-prisma-types"
  output                    = "../src/generated/zod" // Куди генерувати Zod схеми
  createRelationValuesTypes = true // дозволяє створювати типи з урахуванням вкладених моделей
  addIncludeType            = false // додає типи для Prisma Include
  addSelectType             = false
}

// СХЕМИ ДЛЯ СУТНОСТІ USER
// Enum для ролей (як у вашому прикладі)
enum UserRole {
  guest
  user
  admin
}

model User {
  id         Int      @id @default(autoincrement())
  /// @zod.string.email({ message: "Невірний формат email" })
  email      String   @unique
  /// @zod.string.min(8, { message: "Довжина паролю має бути не менше 8 символів" })
  password   String
  /// @zod.string.min(6, { message: "Довжина імені користувача має бути не менше 6 символів" })
  username   String   @unique
  firstname  String
  lastname   String
  // Складний regex краще додати пізніше в коді, щоб не засмічувати схему,
  // але прості перевірки довжини можна залишити тут
  /// @zod.string.length(17, { message: "Довжина номеру телефона має бути 17 символів" })
  phone      String   @unique
  /// @zod.number.int().min(1900, { message: "Рік народження має бути не меншим ніж 1900" })
  birthYear  Int
  profession String
  isMarried  Boolean  @default(false)
  role       UserRole @default(admin)

  address Address? //Поле address опціональне тому, що спочатку створюється User, а потім address. Інакше під час створення user, отримаєм помилкупро відсутність address
  cart    Cart? //Те саме і для Cart
  orders  Order[]
}

model Address {
  //Поле id без autoincrement, бо сутність Address відноситься до User 1 : 1, тому в них однаковий id
  id          Int    @id
  city        String
  street      String
  houseNumber Int

  //Address і User 1 : 1, тому поле id в Address ідентичне полю id в User
  user User @relation(fields: [id], references: [id], onDelete: Cascade)
}

// СХЕМИ ДЛЯ СУТНОСТІ PRODUCT
// Перелік допустимих значень для поля category
enum Category {
  PROCESSORS
  MEMORY
  STORAGE
  GRAPHIC_CARDS
  MOTHERBOARDS
  POWER_SUPPLIES
}

//Схема для сутності Product
model Product {
  id          Int      @id @default(autoincrement())
  productName String
  imgUrls     String[]
  price       Decimal  @db.Decimal(10, 2) // Для грошей краще Decimal, ніж Float
  description String   @db.Text
  quantity    Int      @default(0)
  category    Category
  // Характеристики (Processor, Memory тощо)
  details     Json

  producerId Int
  producer   Producer    @relation(fields: [producerId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  // Індекси для швидкої фільтрації
  @@index([category])
  @@index([price])
  @@index([producerId])
}

//Схема для сутності Producer (виробник товару)
model Producer {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  logoUrl  String?
  // Зв'язок: один виробник має багато товарів
  products Product[]
}

//СХЕМИ ДЛЯ СУТНОСТІ CART
//Схема для сутності Cart
model Cart {
  //Поле id без autoincrement, бо сутність Cart відноситься до User 1 : 1, тому в них однаковий id
  id Int @id

  items CartItem[]
  //Cart і User 1 : 1, тому поле id в Cart ідентичне полю id в User
  user  User       @relation(fields: [id], references: [id], onDelete: Cascade)
}

//Схема для сутності CartItem
model CartItem {
  id       Int @id @default(autoincrement())
  quantity Int @default(1)

  cartId    Int
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  //Комбінація значень полів cartId та productId має бути унікально, щоб користувач не зміг в одній корзині створити
  //різні CartItem з одним і тим же продуктом. Натомість можна змінити лише значення поля quantity
  @@unique([cartId, productId])
}

//СХЕМИ ДЛЯ СУТНОСТІ ORDER
//Перечислення зі статусами замовлення
enum OrderStatus {
  PENDING
  PAID
  DELIVERING
  COMPLETED
  CANCELLED
}

//Схема для сутності Order
model Order {
  id          Int         @id @default(autoincrement())
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)

  items    OrderItem[]
  userId   Int
  user     User        @relation(fields: [userId], references: [id])
  //поля payment та delivery опціональні, щоб запобігти зацикленості при створення всіх трьох сутностей
  payment  Payment?
  delivery Delivery?
}

//Схема для сутності OrderItem
model OrderItem {
  id       Int     @id @default(autoincrement())
  quantity Int
  price    Decimal @db.Decimal(10, 2)

  productId Int
  product   Product @relation(fields: [productId], references: [id])
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

//СХЕМИ ДЛЯ СУТНОСТІ PAYMENT
//Перечислення з методами оплати
enum PaymentMethod {
  CARD
  CASH
}

//Перечислення зі статусами оплати
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MONOBANK
  LIQPAY
  INTERNAL // Для замовлень із сумою 0 або оплати бонусами
}

//Схема Paymant (оплата)
model Payment {
  id         Int             @id @default(autoincrement())
  status     PaymentStatus   @default(PENDING)
  method     PaymentMethod
  amount     Decimal         @db.Decimal(10, 2)
  provider   PaymentProvider
  externalId String?         @unique //ID інвойсу в платіжній системі

  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

//СХЕМИ ДЛЯ СУТНОСТІ DELIVERY
//Перечислення з методами доставки
enum DeliveryMethod {
  NOVA_POSHTA
  UKRPOSHTA
  COURIER
}

//Схема Delivery (доставка)
model Delivery {
  id             Int            @id @default(autoincrement())
  method         DeliveryMethod
  price          Decimal        @default(0) @db.Decimal(10, 2) //значення 0 за змовчуванням, якщо магазин розрховує лише суму завмовлення, а суму доставки клієнт бачитиме вже в сервісі служби доставки
  trackingNumber String? // Номер ТТН для відстеження
  details        Json // Сховище для JSON даних (місто, склад, телефон тощо)

  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
