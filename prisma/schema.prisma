// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator zod {
  provider                  = "zod-prisma-types"
  output                    = "../src/generated/zod" // Куди генерувати Zod схеми
  createRelationValuesTypes = true // дозволяє створювати типи з урахуванням вкладених моделей
  addIncludeType            = false // додає типи для Prisma Include
  addSelectType             = false
}

// СХЕМИ ДЛЯ СУТНОСТІ USER
// Enum для ролей (як у вашому прикладі)
enum UserRole {
  guest
  user
  admin
}

model User {
  id Int @id @default(autoincrement())

  /// @zod.string.email({ message: "Невірний формат email" })
  email String @unique

  /// @zod.string.min(8, { message: "Довжина паролю має бути не менше 8 символів" })
  password String

  /// @zod.string.min(6, { message: "Довжина імені користувача має бути не менше 6 символів" })
  username String @unique

  firstname String
  lastname  String

  // Складний regex краще додати пізніше в коді, щоб не засмічувати схему,
  // але прості перевірки довжини можна залишити тут
  /// @zod.string.length(17, { message: "Довжина номеру телефона має бути 17 символів" })
  phone String @unique

  /// @zod.number.int().min(1900, { message: "Рік народження має бути не меншим ніж 1900" })
  birthYear Int

  profession String
  isMarried  Boolean @default(false)

  role UserRole @default(admin)

  // Зв'язок 1 до 1 з адресою
  address   Address? @relation(fields: [addressId], references: [id])
  addressId Int?     @unique
}

model Address {
  id          Int    @id @default(autoincrement())
  city        String
  street      String
  houseNumber Int

  user User?
}

// СХЕМИ ДЛЯ СУТНОСТІ PRODUCT
// Перелік допустимих значень для поля category
enum Category {
  PROCESSORS
  MEMORY
  STORAGE
  GRAPHIC_CARDS
  MOTHERBOARDS
  POWER_SUPPLIES
}

//Схема для сутності Producer (виробник товару)
model Producer {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  logoUrl  String?
  // Зв'язок: один виробник має багато товарів
  products Product[]
}

//Схема для сутності Product
model Product {
  id          Int       @id @default(autoincrement())
  productName String
  imgUrls     String[]
  price       Decimal   @db.Decimal(10, 2) // Для грошей краще Decimal, ніж Float
  description String    @db.Text
  quantity    Int       @default(0)
  category    Category
  // Характеристики (Processor, Memory тощо)
  details     Json
  producer    Producer? @relation(fields: [producerId], references: [id])
  producerId  Int?

  // Індекси для швидкої фільтрації
  @@index([category])
  @@index([price])
  @@index([producerId])
}
